# =============================================================================
# Backend API server environment (LOCAL DEV) — copy to backend/.env
# =============================================================================
# Why a separate file: the backend server does NOT auto-load the root .env.
# (Prisma's CLI loads the root .env for migrate/push/seed, but the Express
# server + Prisma Client read process.env directly.) Start the backend with
# dotenv preloaded so this file is picked up:
#
#   cd backend
#   node -r dotenv/config -r ts-node/register src/server.ts
#
# See SETUP.md → "Run the backend". (Follow-up: fold dotenv into `npm run dev`.)
# This file is gitignored once copied to backend/.env — never commit real secrets.

# --- Database (local Docker Postgres — docker-compose-pg.yml maps host port 5435) ---
DATABASE_URL="postgresql://postgres:brightboostpass@localhost:5435/brightboost"
DIRECT_URL="postgresql://postgres:brightboostpass@localhost:5435/brightboost"

# --- Auth: signs JWT auth tokens. Any string locally; MUST be a real secret in prod. ---
SESSION_SECRET="local-dev-secret"

# --- API server port ---
PORT=3000
