# =============================================================================
# BrightBoost Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Database (Supabase Postgres in production, local Docker for dev) ---
DATABASE_URL="postgresql://postgres:brightboostpass@localhost:5435/brightboost"
DIRECT_URL="postgresql://postgres:brightboostpass@localhost:5435/brightboost"

# --- Frontend API Base ---
# Canonical variable: VITE_API_BASE
# - Local development: http://localhost:3000
# - Production (same-origin): /api
VITE_API_BASE="http://localhost:3000"

# --- Auth ---
SESSION_SECRET="local-dev-secret-change-in-production"

# --- CORS (optional — Railway domain is hardcoded in server.ts) ---
# Comma-separated list of allowed origins for cross-origin requests.
# ALLOWED_ORIGINS="https://my-frontend.example.com"

# --- Email (optional for local dev) ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=

# --- Legacy (deprecated — do not use for new development) ---
# VITE_AWS_API_URL is no longer used in production. Use VITE_API_BASE instead.
# AZURE_STORAGE_CONNECTION_STRING is no longer used.
