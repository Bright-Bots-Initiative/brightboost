// =============================================================================
// SOURCE OF TRUTH — All Prisma generation and migration uses THIS file.
// backend/prisma/schema.prisma is a secondary copy kept for Dockerfile compat.
// If you edit models here, sync backend/prisma/schema.prisma to match.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

generator clientBackend {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Identity (Merged Legacy + MVP)
// -----------------------------------------------------------------------------

enum AccountMode {
  CLASS_CODE_ONLY
  EMAIL_ONLY
  CLASS_CODE_PLUS_HOME_ACCESS
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  password  String?
  role      String   // "teacher" or "student"
  school    String?
  subject   String?
  bio       String   @default("No bio added")
  grade     Int?

  // K-2 Class Code Login
  loginIcon         String?  // emoji icon for K-2 class-code login
  loginPin          String?  // optional hashed 4-digit PIN
  preferredLanguage String?  // "en" or "es"

  // Home Access (parent/guardian attaches email/password to existing student)
  accountMode       AccountMode @default(CLASS_CODE_ONLY)
  homeAccessEnabled Boolean     @default(false)
  managedByParent   Boolean     @default(false)
  parentEmail       String?

  // Legacy / Hybrid Fields (keep for now to avoid breaking old UI)
  xp        Int      @default(0)
  level     String   @default("Explorer")
  streak    Int      @default(0)
  avatarUrl String?  @default("/robots/robot_default.png")

  // Pathways (secondary-age program layer)
  userType  String   @default("k8")   // "k8" | "pathways"
  ageBand   String?                    // "explorer" (14-15) | "launch" (16-17)
  birthYear Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  enrollments     Enrollment[]
  courses         Course[]      // Teacher's courses
  userBadges      UserBadge[]
  units           Unit[]        // Teacher's units

  // MVP Relations
  progress        Progress[]
  avatar          Avatar?
  weeklySnapshots WeeklySnapshot[]
  pulseResponses  PulseResponse[]
  feedbacks       Feedback[]
  resetTokens     PasswordResetToken[]
  creations       Creation[]    // Phase 0 — kid-authored creations

  // Teacher Enablement Relations
  prepChecklists    TeacherPrepChecklist[]
  pdSessions        PDSession[]
  pdReflections     PDReflection[]
  facultyPosts      FacultyPost[]
  benchmarkAttempts  BenchmarkAttempt[]
  gamePersonalBests  GamePersonalBest[]

  // Pathways Relations
  pathwayCohorts      PathwayCohort[]      // facilitator's cohorts
  pathwayEnrollments  PathwayEnrollment[]
  pathwayMilestones   PathwayMilestone[]
  pathwayLabAttempts  PathwayLabAttempt[]
  pathwayXpEvents     PathwayXpEvent[]
  pathwayGamification PathwayGamification?
  pathwayBadges       PathwayBadge[]
  pathwayDailyGoals   PathwayDailyGoal[]
  pathwayCtfAttempts  PathwayCtfAttempt[]
  pathwayCtfSolves    PathwayCtfSolve[]
  pathwayCtfTeams     PathwayCtfTeamMember[]
  pathwayOnboarding   PathwayOnboarding?
  pathwayGlossaryViews PathwayGlossaryView[]
}

// -----------------------------------------------------------------------------
// MVP: Learning Content (Strict Hierarchy)
// -----------------------------------------------------------------------------

model Module {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String
  level       String  // "K-2", "3-5", etc.
  published   Boolean @default(false)
  units       Unit[]
  badges      Badge[]
}

model Unit {
  id       String   @id @default(cuid())
  moduleId String
  title    String
  order    Int
  lessons  Lesson[]
  
  Module      Module   @relation(fields: [moduleId], references: [id])

  // Relations
  teacherId   String
  teacher     User     @relation(fields: [teacherId], references: [id])
  activities  Activity[]

  // Index for filtering lessons by teacher
  @@index([teacherId])
  // Index for filtering units by module
  @@index([moduleId])
}

model Lesson {
  id        String   @id @default(cuid())
  unitId    String
  title     String
  order     Int

  Unit      Unit       @relation(fields: [unitId], references: [id])
  activities Activity[]

  // Index for filtering lessons by unit
  @@index([unitId])
}

model Activity {
  id       String       @id @default(cuid())
  lessonId String
  title    String
  kind     ActivityKind
  order    Int
  content  String?      // JSON or HTML string

  Lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // Explicit relation to Unit to satisfy Unit.activities[]
  unitId   String?
  Unit     Unit? @relation(fields: [unitId], references: [id])

  @@unique([lessonId, order]) // renamed from index to order for clarity
  // Index for filtering activities by unit
  @@index([unitId])
}

// -----------------------------------------------------------------------------
// MVP: Progress & Rewards
// -----------------------------------------------------------------------------

enum ActivityKind {
  INFO
  INTERACT
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
}

model Progress {
  id         String         @id @default(cuid())
  studentId  String
  moduleSlug String
  lessonId   String?
  activityId String
  status     ProgressStatus
  timeSpentS Int            @default(0)
  updatedAt  DateTime       @updatedAt

  User       User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, activityId])
  // Index for counting completed activities (checkUnlocks)
  @@index([studentId, status])
  // Index for fetching progress by module (Module Map)
  @@index([studentId, moduleSlug])
}

model WeeklySnapshot {
  id        String   @id @default(cuid())
  studentId String
  weekStart DateTime // The start date of the week
  data      Json     // Flexible storage for stats: { xp: 0, timeSpent: 0, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, weekStart])
}

// -----------------------------------------------------------------------------
// MVP: Gamification (Avatar + PvP)
// -----------------------------------------------------------------------------

enum Archetype {
  AI
  QUANTUM
  BIOTECH
}

enum AvatarStage {
  GENERAL
  SPECIALIZED
}

model Avatar {
  id        String       @id @default(cuid())
  studentId String       @unique
  stage     AvatarStage  @default(GENERAL)
  archetype Archetype?   // Nullable until user selects specialty
  level     Int          @default(1)
  xp        Int          @default(0)
  hp        Int          @default(100)
  energy    Int          @default(100)

  // General stats (accrue before specialization)
  speed     Int          @default(0)
  control   Int          @default(0)
  focus     Int          @default(0)

  // Loadout/Unlocks
  unlockedAbilities UnlockedAbility[]

  // Matches
  matchesAsP1 Match[] @relation("Player1")
  matchesAsP2 Match[] @relation("Player2")

  User      User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Ability {
  id          String   @id @default(cuid())
  name        String
  archetype   Archetype
  reqLevel    Int
  config      Json     // e.g. { type: "attack", value: 10, cooldown: 1 }
  
  unlockedBy  UnlockedAbility[]
}

model UnlockedAbility {
  id        String   @id @default(cuid())
  avatarId  String
  abilityId String
  equipped  Boolean  @default(false)

  Avatar    Avatar  @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  Ability   Ability @relation(fields: [abilityId], references: [id], onDelete: Cascade)

  @@unique([avatarId, abilityId])
  // Index for finding which users have a specific ability
  @@index([abilityId])
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  FORFEIT
}

model Match {
  id        String      @id @default(cuid())
  player1Id String
  player2Id String?
  status    MatchStatus @default(PENDING)
  winnerId  String?
  band      String      // "K2", "G35"
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  Player1   Avatar      @relation("Player1", fields: [player1Id], references: [id])
  Player2   Avatar?     @relation("Player2", fields: [player2Id], references: [id])

  turns     MatchTurn[]

  // Index for frequent lookups of matches by player
  @@index([player1Id])
  @@index([player2Id])
  // Index for matchmaking queue (finding pending matches in specific band)
  @@index([status, band])
}

model MatchTurn {
  id        String   @id @default(cuid())
  matchId   String
  round     Int
  actorId   String
  action    Json     // { abilityId, damageDealt, ... }
  createdAt DateTime @default(now())

  Match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Index for fetching turns of a match (hot path)
  @@index([matchId])
}

// -----------------------------------------------------------------------------
// Legacy / Unused (Kept for Schema Validation if needed, but safe to ignore)
// -----------------------------------------------------------------------------

model Badge {
  id        String   @id @default(cuid())
  moduleId  String
  slug      String   @unique
  name      String
  criteria  String
  iconKey   String
  xpBonus   Int      @default(0)

  Module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  UserBadge UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  
  User      User     @relation(fields: [userId], references: [id])
  Badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  // Index for finding which users have a specific badge
  @@index([badgeId])
}

model Course {
  id              String   @id @default(cuid())
  name            String
  joinCode        String   @unique @default(cuid())
  teacherId       String
  gradeBand       String   @default("k2") // "k2" or "g3_5"
  kind            String   @default("class") // "class" (teacher) or "home" (parent home group)
  defaultLanguage String   @default("en") // class-level language ("en" or "es")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher              User                    @relation(fields: [teacherId], references: [id])
  enrollments          Enrollment[]
  assignments          Assignment[]
  pulseResponses       PulseResponse[]
  benchmarkAssignments BenchmarkAssignment[]
  moduleAssignments    ClassModuleAssignment[]
  creations            Creation[]              // Phase 0 — group-scoped creations

  // Index for filtering courses by teacher
  @@index([teacherId])
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  grade     String?
  enrolledAt DateTime @default(now())
  
  student  User   @relation(fields: [studentId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])
  
  @@unique([studentId, courseId])
  // Index for filtering enrollments by course
  @@index([courseId])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     String
  status      String   // "Open", "Closed", "Draft"
  activityId  String?  // links to Activity.id for session assignments
  courseId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id])

  // Index for filtering assignments by course
  @@index([courseId])
}

model PulseResponse {
  id           String   @id @default(cuid())
  respondentId String
  courseId     String
  kind         String   // "PRE" or "POST"
  score        Int      // 1-5 overall confidence
  answers      Json?    // optional structured answers
  createdAt    DateTime @default(now())

  respondent   User   @relation(fields: [respondentId], references: [id])
  course       Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([respondentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Teacher Enablement: Prep Toolkit, Resources, PD
// -----------------------------------------------------------------------------

model TeacherPrepChecklist {
  id          String   @id @default(cuid())
  teacherId   String
  moduleSlug  String
  items       Json     // { "review": true, "printQuestions": false, ... }
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, moduleSlug])
}

model Resource {
  id             String   @id @default(cuid())
  title          String
  description    String
  type           String   // WORKSHEET, HANDOUT, GUIDE, LINK
  moduleSlug     String?  // null = general resource
  category       String   // PRE_ACTIVITY, POST_ACTIVITY, ASSESSMENT, SUPPLEMENTAL, GENERAL
  contentHtml    String?  // for generated worksheets/handouts
  contentUrl     String?  // for external links
  printable      Boolean  @default(false)
  titleEs        String?  // Spanish translation (fallback: title)
  descriptionEs  String?  // Spanish translation (fallback: description)
  contentHtmlEs  String?  // Spanish translation (fallback: contentHtml)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([moduleSlug])
  @@index([type])
  @@index([category])
}

model PDSession {
  id                 String   @id @default(cuid())
  teacherId          String
  date               DateTime
  durationMinutes    Int
  topic              String
  facilitator        String?
  notes              String?
  actionItems        Json?    // ["item1", "item2"]
  relatedModuleSlugs Json?    // ["k2-stem-sequencing", ...]
  isTemplate         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teacher            User           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  reflections        PDReflection[]

  @@index([teacherId])
}

model PDReflection {
  id                  String   @id @default(cuid())
  teacherId           String
  pdSessionId         String
  moduleSlug          String?
  whatWorked           String?
  whatToChange         String?
  studentObservations  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  teacher             User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  pdSession           PDSession @relation(fields: [pdSessionId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([pdSessionId])
}

model FacultyPost {
  id         String   @id @default(cuid())
  authorId   String
  moduleSlug String?
  title      String?
  content    String
  isPinned   Boolean  @default(false)
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     FacultyPost?  @relation("Replies", fields: [parentId], references: [id])
  replies    FacultyPost[] @relation("Replies")

  @@index([authorId])
  @@index([parentId])
  @@index([moduleSlug])
}

// -----------------------------------------------------------------------------
// Password Reset & Feedback
// -----------------------------------------------------------------------------

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Feedback {
  id            String   @id @default(cuid())
  userId        String?
  role          String?  // teacher, student, admin, school_leader, community, parent, technical, other
  liked         String?
  confused      String?
  strongest     String?
  pilotInterest String?  // high, medium, low, na
  wantsFollowUp Boolean  @default(false)
  email         String?
  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Benchmark Assessments
// -----------------------------------------------------------------------------

enum BenchmarkKind {
  PRE
  POST
}

enum BenchmarkStatus {
  OPEN
  CLOSED
}

model BenchmarkTemplate {
  id         String   @id @default(cuid())
  title      String
  gradeRange String   // "K-2"
  subject    String   // "STEM Readiness"
  questions  Json     // [{id, prompt, choices: string[], correctIndex: number, skillTag: string}]
  createdAt  DateTime @default(now())

  assignments BenchmarkAssignment[]
}

model BenchmarkAssignment {
  id         String          @id @default(cuid())
  courseId    String
  templateId String
  kind       BenchmarkKind
  status     BenchmarkStatus @default(OPEN)
  createdAt  DateTime        @default(now())

  course   Course            @relation(fields: [courseId], references: [id])
  template BenchmarkTemplate @relation(fields: [templateId], references: [id])
  attempts BenchmarkAttempt[]

  @@unique([courseId, templateId, kind])
  @@index([courseId])
}

model BenchmarkAttempt {
  id             String   @id @default(cuid())
  assignmentId   String
  studentId      String
  answers        Json     // [{questionId, selectedIndex, isCorrect, skillTag}]
  score          Int      // number correct
  totalQuestions Int
  timeSpentS     Int
  createdAt      DateTime @default(now())

  assignment BenchmarkAssignment @relation(fields: [assignmentId], references: [id])
  student    User                @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// -----------------------------------------------------------------------------
// Game Personal Bests — per-student per-game high scores
// -----------------------------------------------------------------------------

model GamePersonalBest {
  id                  String   @id @default(cuid())
  studentId           String
  gameKey             String   // e.g. "rhymo_rhyme_rocket", "boost_path_planner"
  bestScore           Int      @default(0)
  lastScore           Int      @default(0)
  bestStreak          Int      @default(0)
  bestRoundsCompleted Int      @default(0)
  playCount           Int      @default(0)
  firstPlayedAt       DateTime @default(now())
  lastPlayedAt        DateTime @default(now())
  meta                Json?    // optional extra data

  student User @relation(fields: [studentId], references: [id])

  @@unique([studentId, gameKey])
  @@index([studentId])
}

// -----------------------------------------------------------------------------
// Module Families & Variants — grade-banded module content system
// -----------------------------------------------------------------------------

model ModuleFamily {
  id       String @id @default(cuid())
  key      String @unique // e.g. "sequencing", "motion", "sorting", "plant_variables", "bridge"
  title    String // display name: "Sequencing & Debugging"
  iconEmoji String @default("🔬")

  variants ModuleVariant[]
}

model ModuleVariant {
  id             String  @id @default(cuid())
  familyId       String
  band           String  // "k2" or "g3_5"
  version        String  @default("1.0")
  title          String  // "Bug Lab: Sequence & Debug"
  subtitle       String? // "Find the bug in the code!"
  status         String  @default("active") // "active", "draft", "archived"
  moduleSlug     String? // link to existing Module.slug for backward compat
  contentConfig  Json?   // reading, questions, game config, supports, UI metadata

  family      ModuleFamily            @relation(fields: [familyId], references: [id])
  assignments ClassModuleAssignment[]

  @@unique([familyId, band, version])
  @@index([band])
  @@index([familyId])
}

model ClassModuleAssignment {
  id              String    @id @default(cuid())
  courseId         String
  moduleVariantId String
  orderIndex      Int       @default(0)
  isLocked        Boolean   @default(false)
  dueAt           DateTime?
  assignedAt      DateTime  @default(now())

  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleVariant ModuleVariant @relation(fields: [moduleVariantId], references: [id])

  @@unique([courseId, moduleVariantId])
  @@index([courseId])
}

// -----------------------------------------------------------------------------
// Pathways — secondary-age (14-17) program layer
// -----------------------------------------------------------------------------

model PathwayCohort {
  id            String   @id @default(cuid())
  name          String
  band          String   // "explorer" | "launch" | "mixed"
  sitePartner   String?
  facilitatorId String
  facilitator   User     @relation(fields: [facilitatorId], references: [id])
  startDate     DateTime?
  endDate       DateTime?
  trackIds      String[] // which tracks are active for this cohort
  joinCode      String   @unique
  description   String?
  maxEnrollment Int?     @default(25)
  status        String   @default("draft") // draft | active | paused | ended | archived
  notes         Json?    // facilitator notes — array of { text, author, ts }
  createdAt     DateTime @default(now())
  // `@default(now())` is here so `prisma db push` (the production fallback
  // when `migrate deploy` errors P3005) can add the column to tables that
  // already have rows. Migrations apply `DEFAULT CURRENT_TIMESTAMP` to the
  // SQL column either way.
  updatedAt     DateTime @default(now()) @updatedAt

  enrollments   PathwayEnrollment[]
  ctfTeams      PathwayCtfTeam[]

  @@index([facilitatorId])
  @@index([status])
}

model PathwayEnrollment {
  id         String        @id @default(cuid())
  userId     String
  cohortId   String
  user       User          @relation(fields: [userId], references: [id])
  cohort     PathwayCohort @relation(fields: [cohortId], references: [id])
  enrolledAt DateTime      @default(now())
  status     String        @default("active") // active | completed | dropped

  @@unique([userId, cohortId])
  @@index([cohortId])
}

model PathwayMilestone {
  id          String    @id @default(cuid())
  userId      String
  trackSlug   String
  moduleSlug  String
  status      String    @default("not_started") // not_started | in_progress | completed
  score       Int?
  completedAt DateTime?
  artifacts   Json?
  createdAt   DateTime  @default(now())

  // Section-level progress for the Cyber Launch 6-section flow
  // (hook, reading, lesson, practice, homework, quiz). Modules that don't
  // use this flow leave the fields at their defaults.
  hookCompleted     Boolean @default(false)
  readingCompleted  Boolean @default(false)
  lessonCompleted   Boolean @default(false)
  practiceCompleted Boolean @default(false)
  homeworkSubmitted Boolean @default(false)
  homeworkResponse  String?
  quizCompleted     Boolean @default(false)
  quizScore         Int?
  timeSpentMinutes  Int     @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, trackSlug, moduleSlug])
  @@index([userId])
}

// Sandbox lab attempts (Password Strength Lab, Phishing Showdown, etc.).
// Independent of PathwayMilestone so labs can live outside any module and
// students can attempt the same lab many times. `output` is the portfolio
// artifact (e.g., Red Flag Field Guide, personal password policy).
model PathwayLabAttempt {
  id          String   @id @default(cuid())
  userId      String
  labSlug     String   // "password-strength" | "phishing-showdown" | ...
  mode        String?  // optional sub-mode (e.g., phishing "training" | "timed" | "boss")
  score       Int      @default(0)
  hintsUsed   Int      @default(0)
  output      Json?    // portfolio artifact data
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, labSlug])
  @@index([userId])
}

// ─── Gamification 1.5 ────────────────────────────────────────────────────────
// Append-only log of every XP grant; source of truth for analytics and for
// reconstructing the cached state in PathwayGamification when needed. Source
// is a closed enum encoded as a string for forward-compat with new triggers.
model PathwayXpEvent {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // positive only — we never deduct XP
  source      String   // "section" | "quiz" | "homework" | "module_complete" | "lab_complete" | "lab_high_score" | "daily_goal" | "streak_bonus" | "badge_earned"
  sourceRefId String?  // module slug, lab slug, badge slug, etc.
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, source])
  @@index([userId, source, sourceRefId])
}

// Cached per-user gamification state. Updated atomically alongside every
// XP event so home page reads don't need to scan the event log.
model PathwayGamification {
  userId                    String    @id
  totalXp                   Int       @default(0)
  currentLevel              Int       @default(1)
  currentStreak             Int       @default(0)
  longestStreak             Int       @default(0)
  lastActiveDate            DateTime?
  streakFreezesAvailable    Int       @default(1)
  streakFreezesUsedThisWeek Int       @default(0)
  lastFreezeRefresh         DateTime?
  updatedAt                 DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// Badges a user has earned. Unique per (user, slug) — idempotent.
model PathwayBadge {
  id        String   @id @default(cuid())
  userId    String
  slug      String   // "cyber_curious" | "phishing_hunter" | ...
  earnedAt  DateTime @default(now())
  metadata  Json?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, slug])
  @@index([userId, earnedAt])
}

// Per-day goal sheet. Goals payload is a small JSON array; allComplete and
// bonusAwarded are denormalized so we can scan facilitator dashboards without
// parsing JSON.
model PathwayDailyGoal {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  goals        Json     // [{slug, label, target, current, completed}]
  allComplete  Boolean  @default(false)
  bonusAwarded Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── CTF Challenges 2.0 ──────────────────────────────────────────────────────
// Challenge content lives in code (src/constants/ctfChallenges.ts); only
// attempt/solve state is persisted.

model PathwayCtfAttempt {
  id            String   @id @default(cuid())
  userId        String
  challengeSlug String
  submittedFlag String
  isCorrect     Boolean  @default(false)
  hintsUsed     Int      @default(0)
  timeSpentSec  Int      @default(0)
  teamId        String?
  submittedAt   DateTime @default(now())

  user User             @relation(fields: [userId], references: [id])
  team PathwayCtfTeam?  @relation(fields: [teamId], references: [id])

  @@index([userId, challengeSlug])
  @@index([userId, isCorrect])
  @@index([teamId, challengeSlug])
}

// First correct solve per (user, challenge). Drives clean per-user and
// per-cohort stats without re-scanning the attempt log.
model PathwayCtfSolve {
  id            String   @id @default(cuid())
  userId        String
  challengeSlug String
  category      String   // "cryptography" | "web" | "forensics" | "networks"
  difficulty    String   // "easy" | "medium" | "hard" | "expert"
  solvedAt      DateTime @default(now())
  hintsUsed     Int      @default(0)
  totalAttempts Int      @default(1)
  teamId        String?

  user User             @relation(fields: [userId], references: [id])
  team PathwayCtfTeam?  @relation(fields: [teamId], references: [id])

  @@unique([userId, challengeSlug])
  @@index([userId, solvedAt])
  @@index([category])
}

// Team mode is scaffolded in 2.0 (solo-only ships) — UI lands in 2.1.
model PathwayCtfTeam {
  id         String   @id @default(cuid())
  name       String
  cohortId   String?
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  cohort   PathwayCohort?         @relation(fields: [cohortId], references: [id])
  members  PathwayCtfTeamMember[]
  attempts PathwayCtfAttempt[]
  solves   PathwayCtfSolve[]
}

model PathwayCtfTeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   // "navigator" | "log_reader" | "researcher" | "explainer" | "defender"
  joinedAt DateTime @default(now())

  team PathwayCtfTeam @relation(fields: [teamId], references: [id])
  user User           @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// ─── Cyber Skills 101 onboarding (Phase 2.1) ─────────────────────────────────
// One row per user; created when the welcome flow starts, completedAt set when
// they finish all 4 steps. The four step booleans let us resume mid-flow.
model PathwayOnboarding {
  userId            String   @id
  startedAt         DateTime @default(now())
  completedAt       DateTime?

  avatarChosen      Boolean  @default(false)
  skillsTourViewed  Boolean  @default(false)
  skillsTourSkipped Boolean  @default(false)
  missionStatement  String?
  dailyGoalLevel    String?  // "light" | "medium" | "heavy"

  avatarSlug        String?  // "explorer" | "analyst" | "guardian" | ...

  // Phase 2.2 — set to true after the student sees the CTF toolbox intro
  // screen. Lets us show the one-time tour the first time someone opens
  // a challenge.
  toolboxIntroSeen  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

// First-view-only log of glossary terms; drives the vocab-builder badge chain.
model PathwayGlossaryView {
  id       String   @id @default(cuid())
  userId   String
  termSlug String   // "mfa" | "phishing" | ...
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, termSlug])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// A/B Testing — lightweight experiment framework for internal team use
// -----------------------------------------------------------------------------

model Experiment {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  hypothesis   String
  metric       String
  status       String    @default("draft") // draft | running | completed | archived
  trafficSplit Int       @default(50)      // percentage assigned to "variant"
  createdBy    String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  conclusion   String?

  assignments ExperimentAssignment[]
  events      ExperimentEvent[]

  @@index([status])
}

model ExperimentAssignment {
  id           String   @id @default(cuid())
  experimentId String
  userId       String
  variant      String   // "control" | "variant"
  assignedAt   DateTime @default(now())

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, userId])
  @@index([experimentId, variant])
}

model ExperimentEvent {
  id           String   @id @default(cuid())
  experimentId String
  userId       String
  variant      String
  eventName    String
  eventValue   Float?
  metadata     Json?
  timestamp    DateTime @default(now())

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, eventName])
  @@index([experimentId, variant])
}

// -----------------------------------------------------------------------------
// Phase 0 — Creative loop: kid-authored creations (the "make something" model)
// -----------------------------------------------------------------------------
// A Creation is a kid-made artifact scoped to a single group (Course — class or
// home). Foundation for the authorable game (content = challenge config) and the
// group gallery. Visibility is group-scoped only; `SHARED` is the kid-initiated
// "viewable while still in progress" state.

enum CreationStatus {
  IN_PROGRESS // private draft, author-only
  SHARED      // kid chose to share an unfinished work to the group gallery
  COMPLETE    // finished and visible to the group gallery
}

model Creation {
  id        String         @id @default(cuid())
  authorId  String         // the kid (User) who made it
  courseId  String         // group scope (class or home Course)
  type      String         // "data_dash_challenge" | ... (closed allowlist in code)
  title     String?
  content   Json           // artifact payload / challenge config (validated per type)
  status    CreationStatus @default(IN_PROGRESS)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Gallery read: group + visible-status filter
  @@index([courseId, status])
  // Author's own list
  @@index([authorId])
}
